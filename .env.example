# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Authentication (OAuth via Supabase)
# Note: These values are configured inside your Supabase project settings, not here.
# Refer to the README for instructions on obtaining the Client ID and Secret from Google Cloud Console.

# LLM Models (Veloce Copilot AI) 
# check what's the latest and use those as some of these might have been depricated
OPENAI_MODEL=gpt-5-mini-2025-08-07
DEEPSEEK_MODEL=deepseek-chat
GEMINI_MODEL=gemini-3.1-flash-lite-preview


# Encryption
# to get this run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY="your_copied_hex_string_here"

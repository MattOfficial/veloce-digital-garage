# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Authentication (OAuth via Supabase)
# Note: These values are configured inside your Supabase project settings, not here.
# Refer to the README for instructions on obtaining the Client ID and Secret from Google Cloud Console.

# Google Gemini (Veloce Copilot AI)
# The application uses a BYOK (Bring Your Own Key) model, so no central API key is needed here!
GEMINI_MODEL=gemini-2.5-flash
# to get this run
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY="your_copied_hex_string_here"
